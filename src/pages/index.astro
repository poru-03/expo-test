---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TitleLogo from '../components/TitleLogo.astro';
import About from '../components/About.astro';
import UnifiedTimeline from '../components/UnifiedTimeline.astro';
import Archive from '../components/Archive.astro';
import Events from '../components/Events.astro';
import Highlights from '../components/Highlights.astro';
import Legacy from '../components/Legacy.astro';
import Voices from '../components/Voices.astro';
import Partners from '../components/Partners.astro';
import Careers from '../components/Careers.astro';
import Team from '../components/Team.astro';
import FeaturedCTA from '../components/FeaturedCTA.astro';
import Inside from '../components/Inside.astro';
import Launch from '../components/Launch.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/islands/ContactModal.jsx';
---
<Base>
  <div class="preloader" id="preloader" aria-hidden="true">
    <div class="preloader__inner">
      <span class="preloader__count foil-num" id="preloaderCount">0</span>
      <div class="preloader__rule"><div class="preloader__rule-fill" id="preloaderRule"></div></div>
      <div class="preloader__word label label--gold">Exposition · Issue 22</div>
    </div>
  </div>

  <div class="progress" aria-hidden="true"><div class="progress__fill" id="progressFill"></div></div>

  <Nav />

  <main id="top">
    <Hero />
    <TitleLogo />
    <About />
    <UnifiedTimeline />
    <Archive />
    <Events />
    <Highlights />
    <Legacy />
    <Voices />
    <Partners />
    <Careers />
    <Team />
    <FeaturedCTA />
    <Inside />
    <Launch />
    <Contact />
  </main>

  <Footer />

  <ContactModal client:idle />

  <script>
    import '../scripts/site.js';
  </script>
</Base>
