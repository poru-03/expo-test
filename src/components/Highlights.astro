---
import { highlights } from '../data/speakers.js';
const initials = (n) => n.split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('');
---
<section class="section ink-chapter" id="highlights" data-ground="ink">
  <div class="section__inner">
    <div class="section-head section-head--wide reveal">
      <h2 class="display">Undergraduates <em>secured</em> these names</h2>
      <p class="section-head__sub">Not a PR agency. Students secured, interviewed, and hosted every name here.</p>
    </div>
    <div class="people-rail stagger" role="list">
      {highlights.map((s) => (
        <article class="speaker" role="listitem">
          <div class="speaker__photo">
            {s.image
              ? <img src={s.image} alt={s.name} loading="lazy" />
              : <span class="team__fallback">{initials(s.name)}</span>}
            {s.issue && <span class="speaker__issue">{s.issue}</span>}
          </div>
          <h3 class="speaker__name">{s.name}</h3>
          <p class="speaker__role">{s.role}</p>
          {s.company && <p class="speaker__company">{s.company}</p>}
        </article>
      ))}
    </div>
    <div class="section-btns reveal">
      <a class="btn btn--paper" href="#legacy">See the Full Highlights Wall →</a>
    </div>
  </div>
</section>
