---
import HeroCarousel from './islands/HeroCarousel.jsx';
---
<section class="hero ink-chapter" id="hero" data-ground="ink">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__bg-22" aria-hidden="true">22</div>
  
  <div class="hero__scroll-indicator" aria-hidden="true">
    <span>Scroll to explore</span>
    <div class="hero__scroll-line"></div>
  </div>

  <div class="hero__carousel-wrapper">
    <HeroCarousel client:load />
  </div>

  <div class="grain" aria-hidden="true"></div>
</section>
