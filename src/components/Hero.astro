---
// The monument hero — canvas gold-dust + breathing bloom + per-letter masthead
---
<section class="hero ink-chapter" id="hero" data-ground="ink">
  <div class="hero__stage" id="heroStage">
    <canvas class="hero__dust" id="heroDust" aria-hidden="true"></canvas>
    <div class="hero__bloom" aria-hidden="true"></div>
    <span class="hero__ghost foil-num" aria-hidden="true">22</span>
    <div class="hero__content">
      <span class="hero__eyebrow label" id="heroEyebrow">The Annual Business Magazine</span>
      <h1 class="hero__wordmark display" id="heroWordmark">EXPOSITION</h1>
      <div class="hero__meta" id="heroMeta">
        <span class="hero__issue">Issue <span class="foil-num">22</span></span>
        <span class="hero__edition label">Department of Industrial Management · University of Kelaniya · 2026</span>
      </div>
      <p class="hero__subhead">Where Students Meet Industry — the flagship student-run magazine and industry-engagement platform of the Department of Industrial Management, University of Kelaniya. For over 20 years, undergraduates have researched it, written it, and landed the industry names in it — no staff, no agency.</p>
      <p class="hero__thisyear label">Issue 22 launches January 2027. Explore two decades of past issues while you wait.</p>
      <div class="hero__actions">
        <a class="btn btn--paper" href="#archive">Read the Magazine</a>
        <a class="btn btn--paper hero__actions-secondary" href="#this-year">See What's On This Year</a>
      </div>
    </div>
    <a class="hero__cue" href="#about" id="heroCue" aria-label="Scroll to begin">
      <span class="label">Begin</span>
      <span class="hero__cue-line"></span>
    </a>
    <div class="grain" aria-hidden="true"></div>
  </div>
</section>
