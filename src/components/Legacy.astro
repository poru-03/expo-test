---
import { keynoteHighlights, featuredInterviews } from '../data/speakers.js';
import { legacyTestimonials } from '../data/testimonials.js';
const initials = (n) => n.split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('');
---
<section class="section ink-chapter" id="legacy" data-ground="ink">
  <div class="section__inner">
    <div class="section-head reveal">
      <span class="label label--gold">Our Legacy</span>
      <h2 class="display">Two Decades of Excellence, <em>Built by Students</em></h2>
    </div>
    <div class="voices2__stats reveal" style="margin-bottom:clamp(48px,5vw,72px)">
      <div class="voices2__stat"><div class="n">20</div><div class="l label">Years</div></div>
      <div class="voices2__stat"><div class="n">20+</div><div class="l label">Issues</div></div>
      <div class="voices2__stat"><div class="n">100+</div><div class="l label">Interviews</div></div>
    </div>
    <p class="reveal archive__lede" style="color:var(--paper-70)">Two decades of undergraduates landing the conversations that matter — read the full history, every keynote, every interview.</p>

    <h3 class="legacy__subhead reveal">Keynote Highlights — <em>Voices that fuelled our vision</em></h3>
    <div class="people-rail" role="list">
      {keynoteHighlights.map((s) => (
        <article class="speaker" role="listitem">
          <div class="speaker__photo">
            {s.image
              ? <img src={s.image} alt={s.name} loading="lazy" />
              : <span class="team__fallback">{initials(s.name)}</span>}
            {s.issue && <span class="speaker__issue">{s.issue}</span>}
          </div>
          <h3 class="speaker__name">{s.name}</h3>
          <p class="speaker__role">{s.role}</p>
          {s.company && <p class="speaker__company">{s.company}</p>}
          {s.tags?.length > 0 && (
            <div class="speaker__tags">
              {s.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          )}
          {s.note && <p class="speaker__note" title={s.note}>⚠ Corrected — see note</p>}
        </article>
      ))}
    </div>

    <h3 class="legacy__subhead reveal" style="margin-top:clamp(56px,6vw,86px)">Featured Interviews</h3>
    <div class="highlights__grid">
      {featuredInterviews.map((p) => (
        <article class="hl-card reveal">
          <span class="label label--gold">{p.category} · {p.issue}</span>
          <div class="hl-card__foot" style="margin-top:0">
            {p.image
              ? <img class="hl-card__avatar" src={p.image} alt={p.name} loading="lazy" />
              : <span class="hl-card__avatar" style="display:grid;place-items:center;font-family:var(--serif);color:var(--gold-600)">{initials(p.name)}</span>}
            <div>
              <div class="hl-card__name">{p.name}</div>
              <div class="hl-card__role">{p.role}</div>
            </div>
          </div>
          {p.company && <p class="hl-card__role" style="margin-top:4px">{p.company}</p>}
        </article>
      ))}
    </div>

    <h3 class="legacy__subhead reveal" style="margin-top:clamp(56px,6vw,86px)">What Our Partners & Guests Say</h3>
    <div class="highlights__grid">
      {legacyTestimonials.map((t) => (
        <article class="hl-card reveal">
          <p class="hl-card__quote">&ldquo;{t.quote}&rdquo;</p>
          <div class="hl-card__foot">
            {t.image
              ? <img class="hl-card__avatar" src={t.image} alt={t.name} loading="lazy" />
              : <span class="hl-card__avatar" style="display:grid;place-items:center;font-family:var(--serif);color:var(--gold-600)">{initials(t.name)}</span>}
            <div>
              <div class="hl-card__name">{t.name}</div>
              <div class="hl-card__role">{t.tagline} · {t.subtext}</div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="reveal" style="margin-top:clamp(48px,5vw,72px);display:flex;gap:16px;flex-wrap:wrap">
      <a class="btn btn--paper" href="#archive">Read the Magazine</a>
      <a class="btn btn--paper" href="#partners">Become a Partner</a>
    </div>
  </div>
  <div class="grain" aria-hidden="true"></div>
</section>
