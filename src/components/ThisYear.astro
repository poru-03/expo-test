---
const dates = [
  { when: 'August 2026', what: 'EXPO NEXT 10 registration opens' },
  { when: 'Late August 2026', what: 'University Tech Events Hub goes live', note: 'currently gathering listings, may launch as “Coming Soon”' },
  { when: '11–12 January 2027', what: 'Industrial Week & Career Fair' },
  { when: '15 January 2027', what: 'Industrial Forum' },
  { when: '15 January 2027', what: 'Exposition Magazine Launch: Issue 22 launch + EXPO NEXT 10 prize-giving' },
];
const whatsNew = ['Voices of Vision (podcast)', 'University Tech Events Hub', 'EXPO NEXT 10'];
---
<section class="section" id="this-year" data-ground="paper">
  <div class="section__inner">
    <div class="section-head reveal">
      <span class="label label--gold">This Year · Issue 22</span>
      <h2 class="display">Where Students Meet <em>Industry</em></h2>
    </div>
    <div class="issue__grid">
      <div class="issue__copy">
        <p class="lede reveal">A professional, elegant, modern theme, consistent with Exposition's identity as a serious business publication.</p>
        <hr class="hairline issue__rule reveal" />
        <div class="datelist">
          {dates.map((d) => (
            <div class="datelist__row reveal">
              <span class="datelist__when label label--gold">{d.when}</span>
              <span class="datelist__what">{d.what}{d.note && <em class="datelist__note"> ({d.note})</em>}</span>
            </div>
          ))}
        </div>
        <p class="reveal" style="margin-top:28px"><strong>Venue:</strong> A8 Auditorium, University of Kelaniya, for the Career Fair, Forum, and Magazine Launch. Open to partnering with other halls on campus if capacity requires it.</p>
      </div>
      <aside class="thisyear__new reveal">
        <span class="label label--gold">New This Year</span>
        <ul class="thisyear__new-list">
          {whatsNew.map((w, i) => (
            <li>
              <span class="thisyear__new-num foil-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="thisyear__new-text">{w}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>
