---
const nav = [
  { href: '#top', label: 'Home' },
  { href: '#archive', label: 'Read the Magazine' },
  { href: '#events', label: 'Events' },
  { href: '#highlights', label: 'Highlights' },
  { href: '#partners', label: 'Partners' },
  { href: '#careers', label: 'Careers' },
  { href: '#contact', label: 'Contact' },
];
const social = [
  { href: 'https://facebook.com/Exposition.MIT', label: 'Facebook' },
  { href: 'https://linkedin.com/company/theexposition', label: 'LinkedIn' },
  { href: 'https://instagram.com/exposition_lk', label: 'Instagram' },
];
---
<footer class="colophon ink-chapter" data-ground="ink">
  <div class="colophon__inner">
    <div class="colophon__top">
      <div class="colophon__unit">
        <img class="colophon__wordmark" src="/assets/logo.png" alt="Exposition — Bridging Innovation, Inspiring Excellence" />
        <p>Celebrating academic excellence through compelling storytelling and meaningful partnerships.</p>
        <div class="colophon__contact">
          <span>University of Kelaniya, Sri Lanka</span>
          <a href="mailto:exposition.uok@gmail.com">exposition.uok@gmail.com</a>
        </div>
      </div>
      <nav class="colophon__links" aria-label="Footer">
        {nav.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <nav class="colophon__links" aria-label="Social">
        {social.map((l) => <a href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
      </nav>
    </div>
    <hr class="colophon__rule" />
    <div class="colophon__base">
      <span>© 2026 Exposition. All Rights Reserved.</span>
      <span>Department of Industrial Management · University of Kelaniya</span>
    </div>
  </div>
  <div class="grain" aria-hidden="true"></div>
</footer>
