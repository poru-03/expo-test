---
import PartnersFilter from './islands/PartnersFilter.jsx';
const stats = [
  { n: '100+', l: 'Total Partners' },
  { n: '20+', l: 'Years of Partnership' },
  { n: '50+', l: 'Industries Covered' },
];
---
<section class="section" id="partners" data-ground="paper">
  <div class="section__inner">
    <div class="section-head reveal">
      <span class="label label--gold">Official Partners</span>
      <h2 class="display">Proudly supported by industry <em>leaders</em></h2>
    </div>
    <p class="reveal archive__lede">Over 20 years, Exposition has partnered with 100+ organisations across 50+ industries, from Rexona and CIMA Sri Lanka to MAS Holdings and Samsung Sri Lanka. Shown below as a record of trust built over two decades, not a claim of current Issue 22 sponsorship.</p>
    <div class="voices2__stats reveal" style="grid-template-columns:repeat(3,1fr);margin-bottom:clamp(40px,4.4vw,64px)">
      {stats.map((s) => (
        <div class="voices2__stat">
          <div class="n" style="background:none;-webkit-text-fill-color:var(--ink);color:var(--ink)">{s.n}</div>
          <div class="l label" style="color:var(--ink-60)">{s.l}</div>
        </div>
      ))}
    </div>
    <PartnersFilter client:visible />
    <div class="reveal" style="margin-top:40px">
      <a class="btn btn--ink" href="#contact" data-open-contact>Become a Partner →</a>
    </div>
  </div>
</section>
