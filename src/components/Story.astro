---
import { milestones } from '../data/timeline.js';
---
<section class="story ink-chapter" id="story" data-ground="ink">
  <div class="story__head">
    <h2 class="display">Our Journey — <em>The Exposition Story</em></h2>
    <span class="story__hint">Scroll to move through the season →</span>
  </div>
  <div class="story__viewport" id="storyViewport">
    <div class="story__line" aria-hidden="true"></div>
    <div class="story__track" id="storyTrack">
      {milestones.map((m) => (
        <article class="milestone">
          <span class="milestone__idx">{m.idx}</span>
          <span class="milestone__cat label">{m.cat}</span>
          <h3 class="milestone__title">{m.title}</h3>
          <p class="milestone__desc">{m.desc}</p>
          <span class="milestone__spacer"></span>
        </article>
      ))}
    </div>
  </div>
  <div class="grain" aria-hidden="true"></div>
</section>
