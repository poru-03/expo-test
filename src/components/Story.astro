---
import { milestones } from '../data/timeline.js';
---
<section class="section ink-chapter" id="story" data-ground="ink">
  <div class="section__inner">
    <div class="section-head reveal">
      <h2 class="display">Our Journey</h2>
    </div>
    <div class="story__grid stagger">
      {milestones.map((m) => (
        <article class="milestone">
          <span class="milestone__idx foil-num">{m.idx}</span>
          <span class="milestone__cat label">{m.cat}</span>
          <h3 class="milestone__title">{m.title}</h3>
          <p class="milestone__desc">{m.desc}</p>
        </article>
      ))}
    </div>
  </div>
  <div class="grain" aria-hidden="true"></div>
</section>
