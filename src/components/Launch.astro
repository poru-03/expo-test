<section class="launch ink-chapter" id="launch" data-ground="ink">
  <div class="launch__stage" id="launchStage">
    <div class="launch__media">
      <video id="pressVideo" muted playsinline preload="none" aria-hidden="true"></video>
      <img class="launch__poster" id="pressPoster" src="/assets/cover.webp" alt="" aria-hidden="true" />
    </div>
    <span class="launch__ghost22 foil-num" aria-hidden="true">22</span>
    <div class="launch__content">
      <span class="label label--gold">Exposition Magazine Launch</span>
      <h2 class="display">The season closes. The issue <em>opens</em>.</h2>
      <p>The closing event of Industrial Week — one evening, one stage, and the official launch of Exposition Issue 22.</p>
    </div>
    <div class="grain" aria-hidden="true"></div>
  </div>
</section>
