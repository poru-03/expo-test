---
import { interviewHighlights } from '../data/speakers.js';
const initials = (n) => n.split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('');
---
<section class="section" id="interviews" data-ground="paper">
  <div class="section__inner">
    <div class="section-head reveal">
      <span class="label label--gold">Interview Highlights</span>
      <h2 class="display">Insights from industry <em>pioneers</em></h2>
    </div>
    <div class="highlights__grid">
      {interviewHighlights.map((p) => (
        <article class="hl-card reveal">
          <span class="label label--gold">In Conversation</span>
          <div class="hl-card__foot" style="margin-top:0">
            {p.image
              ? <img class="hl-card__avatar" src={p.image} alt={p.name} loading="lazy" />
              : <span class="hl-card__avatar" style="display:grid;place-items:center;font-family:var(--serif);color:var(--gold-600)">{initials(p.name)}</span>}
            <div>
              <div class="hl-card__name">{p.name}</div>
              <div class="hl-card__role">{p.role}</div>
            </div>
          </div>
          {p.company && <p class="hl-card__role" style="margin-top:4px">{p.company}</p>}
          {p.tags?.length > 0 && (
            <div class="speaker__tags" style="margin-top:auto">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
