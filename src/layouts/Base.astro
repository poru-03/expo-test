---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Exposition Issue 22 — Bridging Innovation, Inspiring Excellence',
  description = 'Exposition Issue 22 — the annual flagship business magazine of the Department of Industrial Management, University of Kelaniya. Bridging Innovation, Inspiring Excellence.',
} = Astro.props;
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:wght@500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/assets/logo.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
